<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="2dp">


    <androidx.cardview.widget.CardView
        android:id="@+id/cv_indicators"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:alpha="0.8"
        app:cardCornerRadius="13dp">

        <LinearLayout
            android:id="@+id/ll_background"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/colorAccent">

            <!-- App Icon shown briefly when sensor is triggered -->
            <ImageView
                android:id="@+id/iv_app_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="2dp"
                android:visibility="gone"
                android:scaleType="centerCrop"
                tools:ignore="UseAppTint" />

            <!-- App Name shown briefly when sensor is triggered -->
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="120dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="10sp"
                android:paddingEnd="4dp"
                android:visibility="gone"
                tools:text="Camera" />

            <ImageView
                android:id="@+id/iv_cam"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/camera_indicator2"
                android:tint="@color/white"
                tools:ignore="UseAppTint"
                android:visibility="visible"/>

            <ImageView
                android:id="@+id/iv_mic"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/microphone_indicator2"
                android:tint="@color/white"
                tools:ignore="UseAppTint"
                android:visibility="visible"/>

            <ImageView
                android:id="@+id/iv_loc"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_weight="1"
                android:padding="4dp"
                android:src="@drawable/location_indicator"
                android:tint="@color/white"
                tools:ignore="UseAppTint"
                android:visibility="visible"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>